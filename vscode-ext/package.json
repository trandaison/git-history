{
  "name": "git-file-history",
  "displayName": "Git File History",
  "description": "Modern, fast and intuitive tool for browsing the history and files in any git repository",
  "version": "1.0.1",
  "repository": "pomber/git-history",
  "publisher": "pomber",
  "license": "MIT",
  "keywords": [
    "git",
    "history",
    "log",
    "file",
    "commit",
    "show"
  ],
  "engines": {
    "vscode": "^1.30.2"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#011627",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:extension.git-file-history"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.git-file-history",
        "title": "Git File History"
      }
    ]
  },
  "scripts": {
    "build-site": "cd .. && cross-env NODE_OPTIONS=--openssl-legacy-provider PUBLIC_URL=. REACT_APP_GIT_PROVIDER=vscode yarn build && rm -fr vscode-ext/site/ && cp -r build/ vscode-ext/site/",
    "build": " yarn build-site",
    "watch-site": "chokidar \"../src/**/*\" \"../public/**/*\" \"../craco.config.js\" -i \"../build/**/*\" -c \"yarn build-site\"",
    "dev-site": "yarn build-site && yarn watch-site",
    "postinstall": "node ./scripts/postinstall.js",
    "test": "node ./node_modules/vscode/bin/test",
    "vscode:prepublish": "yarn build"
  },
  "devDependencies": {
    "@types/mocha": "^2.2.42",
    "@types/node": "^10.12.21",
    "cross-env": "^5.2.0",
    "eslint": "^5.13.0",
    "typescript": "^3.3.1",
    "vscode": "^1.1.28"
  },
  "dependencies": {
    "chokidar-cli": "^3.0.0",
    "execa": "^1.0.0"
  }
}
